APP_NAME="Machine Error Helper Testing"
APP_ENV=testing-server
APP_KEY=
APP_DEBUG=false
APP_URL=https://testing.example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=machine_error_helper_testing
DB_USERNAME=app_testing
DB_PASSWORD=change-this-testing-db-password

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
REDIS_QUEUE_RETRY_AFTER=7200
HORIZON_JOB_TIMEOUT=3600

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="testing@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

VIEW_COMPILED_PATH=/tmp

GEMINI_API_KEY=
PRISM_REQUEST_TIMEOUT=60
PRISM_SERVER_ENABLED=false

MANUAL_AI_EXTRACTION_ENABLED=false
MANUAL_AI_PROVIDER=gemini
MANUAL_AI_MODEL=gemini-2.5-flash
SCREENSHOT_AI_PROVIDER=gemini
SCREENSHOT_AI_MODEL=gemini-2.5-pro
SCREENSHOT_AI_TIMEOUT=60
MANUAL_AI_MAX_CHUNKS_PER_IMPORT=40
MANUAL_AI_MAX_CHUNK_CHARACTERS=6000
MANUAL_AI_MIN_CONFIDENCE=0.35

TELESCOPE_ENABLED=true
TELESCOPE_ALLOWED_EMAILS=admin@example.com
