# Docker Compose settings for the server-side testing environment.
#
# Copy this file to .env.testing-server on the server and edit the values.

COMPOSE_PROJECT_NAME=machine-error-helper-testing

# Bind to 127.0.0.1 when a reverse proxy or Cloudflare Tunnel is on the same
# server. Use 0.0.0.0 only when you intentionally want this port exposed.
TESTING_HTTP_BIND=127.0.0.1
TESTING_HTTP_PORT=8092

# Create this token in Cloudflare Zero Trust when creating the testing tunnel.
# Configure the tunnel public hostname service URL as: http://nginx:80
CLOUDFLARED_TUNNEL_TOKEN=paste-cloudflare-testing-tunnel-token-here

POSTGRES_DB=machine_error_helper_testing
POSTGRES_USER=app_testing
POSTGRES_PASSWORD=change-this-testing-db-password
